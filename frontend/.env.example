# ============================================================
# EnterpriseRAG Frontend — Environment Variables
# ============================================================
# Copy this file to .env.local for local overrides.
# In production (Render), set these as Environment Variables
# in the Render dashboard — do NOT commit a .env file.
# ============================================================

# URL of the deployed backend API.
# On Render: set this to your backend Web Service URL,
# e.g. https://enterpriserag-backend.onrender.com
#
# Leave unset for local development (defaults to http://localhost:8000).
VITE_API_URL=https://your-backend-service.onrender.com
